{
  "version": 2,
  "defaultSystem": "REMY",
  "systems": {
    "REMY": {
      "alias": "REMY",
      "status": "active-default",
      "route": "/",
      "renderMode": "source-mirror",
      "runtimeContracts": {
        "page": "/app/page.tsx",
        "cssRoutes": [
          "/app/remy/withremy.css/route.ts",
          "/app/remy/wireframe-remy.css/route.ts"
        ],
        "jsRoute": "/app/remy/wireframe-remy.js/route.ts"
      },
      "sourceOfTruthFiles": {
        "html": "/wireframe-remy.html",
        "css": "/wireframe-remy.css",
        "js": "/wireframe-remy.js",
        "designTokens": "/design-system/withremy/withremy.css"
      },
      "ctaClassFamilies": [
        ".wr-cta-join",
        ".wf-email-cta__button",
        ".wf-pricing-card-cta",
        ".wf-pricing-details-link",
        ".wf-tenant-submit"
      ],
      "assetRoot": "/assets/remy/",
      "assetPrefix": "remy-"
    },
    "SAAS-BLUE": {
      "alias": "SAAS-BLUE",
      "status": "archived-available",
      "route": "/designs/saas-blue-theme/index.html",
      "renderMode": "static-html",
      "sourceOfTruthFiles": {
        "html": "/designs/saas-blue-theme/index.html",
        "css": "/designs/saas-blue-theme/styles.css",
        "js": "/designs/saas-blue-theme/script.js"
      },
      "ctaClassFamilies": [
        ".btn.btn-ghost",
        ".btn.btn-cta",
        ".btn.btn-primary",
        ".btn.btn-secondary"
      ],
      "assetRoot": "/assets/saas-blue-theme/",
      "assetPrefix": "saas-blue-"
    }
  }
}
