{
  "name": "remy-next-foundation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:selector-contracts": "node scripts/check-selector-contracts.mjs",
    "check:token-integrity": "node scripts/check-token-integrity.mjs",
    "parity:check": "node scripts/parity-check.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:full": "npm audit --audit-level=high",
    "verify": "npm run lint && npm run typecheck && npm run check:selector-contracts && npm run check:token-integrity && npm run build && npm run audit:prod"
  },
  "dependencies": {
    "@imagekit/next": "^2.1.5",
    "agentation": "^2.2.1",
    "next": "^15.5.10",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.5.10",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.52.0",
    "pngjs": "^7.0.0",
    "typescript": "5.6.3"
  }
}
